# Required.
TELEGRAM_BOT_TOKEN=put-your-botfather-token-here
ALCHEMY_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/PUT_YOUR_ALCHEMY_KEY
WALLETCONNECT_PROJECT_ID=put-your-walletconnect-project-id-here

# Auto-generated by Render if you use render.yaml. Locally: openssl rand -hex 32
MASTER_KEY=64-hex-chars-here

# After Render deploys, this is your service's public URL.
PUBLIC_URL=https://polydcopier.onrender.com

# Local SQLite path. Render uses /data/bot.db on the persistent disk.
DB_PATH=./data/bot.db

# Set to 1 to record-but-not-submit. Useful for verifying detection latency.
PAPER_TRADE=0

PORT=3000
